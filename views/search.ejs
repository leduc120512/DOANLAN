<div class="py-8">
  <% const currentKeyword = typeof keyword !== 'undefined' ? keyword : ''; %>
  <% if (categories && categories.length > 0) { %>
  <div class="mb-6">
    <p class="font-semibold text-gray-700 mb-3">Lọc nhanh theo danh mục</p>
    <div class="flex gap-3 overflow-x-auto pb-2">
      <a
        href="/search?keyword=<%= encodeURIComponent(currentKeyword) %>&category=all"
        class="min-w-28 px-3 py-2 rounded-lg border <%= selectedCategory === 'all' ? 'border-blue-600 bg-blue-50 text-blue-700' : 'border-gray-200 text-gray-700' %> text-center"
      >
        Tất cả
      </a>
      <% categories.forEach(cat => { %>
      <% const isSelectedCategory = selectedCategory && selectedCategory.toString() === cat._id.toString(); %>
      <a
        href="/search?keyword=<%= encodeURIComponent(currentKeyword) %>&category=<%= cat._id %>"
        class="min-w-36 px-2 py-2 rounded-lg border <%= isSelectedCategory ? 'border-blue-600 bg-blue-50' : 'border-gray-200 bg-white' %>"
      >
        <div class="flex items-center gap-2">
          <% if (cat.image) { %>
          <img src="<%= cat.image %>" alt="<%= cat.name %>" class="w-9 h-9 rounded object-cover">
          <% } else { %>
          <div class="w-9 h-9 rounded bg-gray-100 flex items-center justify-center text-gray-400">🖼️</div>
          <% } %>
          <span class="text-sm font-medium text-gray-700"><%= cat.name %></span>
        </div>
      </a>
      <% }) %>
    </div>
  </div>
  <% } %>

  <!-- Products Grid -->
  <% if (products && products.length > 0) { %>
  <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
    <% products.forEach(product => { %>
    <% const displayImage = (product.images && product.images.length > 0) ? product.images[0] : product.image; %>
    <div
      class="bg-white rounded-lg shadow-lg hover:shadow-xl transition overflow-hidden"
    >
      <div class="bg-gray-200 h-48 flex items-center justify-center">
        <% if (displayImage) { %>
        <img
          src="<%= displayImage %>"
          alt="<%= product.name %>"
          class="w-full h-full object-cover"
        />
        <% } else { %>
        <span class="text-gray-400 text-5xl">📦</span>
        <% } %>
      </div>
      <div class="p-4">
        <h3 class="font-bold text-base mb-2 line-clamp-2">
          <%= product.name %>
        </h3>
        <p class="text-gray-600 text-xs mb-3 line-clamp-2">
          <%= product.description %>
        </p>
        <div class="flex justify-between items-center mb-3">
          <span class="text-blue-600 font-bold"
            ><%= product.price.toLocaleString() %>₫</span
          >
          <span class="text-yellow-400 text-sm"
            >★ <%= product.rating.toFixed(1) %></span
          >
        </div>
        <div class="flex gap-2">
          <a
            href="/product/<%= product._id %>"
            class="flex-1 btn-primary text-center text-sm"
            >Chi tiết</a
          >
          <button
            class="flex-1 btn-secondary text-sm"
            onclick="addToCart('<%= product._id %>')"
          >
            Thêm
          </button>
        </div>
      </div>
    </div>
    <% }); %>
  </div>
  <% } else { %>
  <div class="bg-white rounded-lg shadow-lg p-8 text-center">
    <p class="text-gray-600 text-xl mb-4">Không tìm thấy sản phẩm nào</p>
    <a href="/" class="btn-primary">Quay lại trang chủ</a>
  </div>
  <% } %>
</div>

<script>
  function addToCart(productId) {
    fetch("/cart/add", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify({
        productId: productId,
        quantity: 1,
      }),
    })
      .then((res) => res.json())
      .then((data) => {
        if (data.success) {
          notify("Đã thêm vào giỏ hàng", "success");
        } else {
          notify(data.error, "error");
        }
      });
  }
</script>
