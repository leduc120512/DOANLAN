<div class="py-8">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-4xl font-bold text-blue-600">Thông báo của tôi</h1>
    <button id="markAllReadBtn" class="btn-secondary">Đánh dấu đã đọc tất cả</button>
  </div>

  <% if (notifications && notifications.length > 0) { %>
    <div class="space-y-4">
      <% notifications.forEach(notification => { %>
        <div class="bg-white rounded-lg shadow p-5 border-l-4 <%= notification.isRead ? 'border-gray-200' : 'border-blue-500' %>">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h2 class="text-lg font-bold <%= notification.isRead ? 'text-gray-700' : 'text-blue-700' %>">
                <%= notification.title %>
              </h2>
              <p class="text-gray-700 mt-1"><%= notification.message %></p>
              <% if (notification.order) { %>
                <a href="/order/<%= notification.order %>" class="inline-block mt-3 text-blue-600 hover:text-blue-800 font-semibold">
                  Xem chi tiết đơn hàng
                </a>
              <% } %>
            </div>
            <div class="text-sm text-gray-500 whitespace-nowrap">
              <%= new Date(notification.createdAt).toLocaleString('vi-VN') %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <div class="bg-white rounded-lg shadow-lg p-12 text-center">
      <p class="text-gray-600 text-xl">Bạn chưa có thông báo nào</p>
    </div>
  <% } %>
</div>

<script>
  document.getElementById('markAllReadBtn')?.addEventListener('click', async () => {
    try {
      const response = await fetch('/user/notifications/read-all', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        }
      });

      const data = await response.json();
      if (data.success) {
        notify('Đã đánh dấu tất cả là đã đọc', 'success');
        window.location.reload();
      } else {
        notify(data.error || 'Không thể cập nhật thông báo', 'error');
      }
    } catch (error) {
      notify('Có lỗi xảy ra', 'error');
    }
  });
</script>
