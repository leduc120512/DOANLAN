<div class="py-8">
  <h1 class="text-4xl font-bold mb-8 text-blue-600">Quản lý danh mục</h1>

  <!-- FORM THÊM DANH MỤC -->
  <div class="bg-white rounded-lg shadow-lg p-8 mb-8">
    <h2 class="text-2xl font-bold mb-6 text-blue-600">Thêm danh mục mới</h2>

    <form onsubmit="addCategory(event)">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
        <div>
          <label class="block font-bold mb-2">Tên danh mục</label>
          <input type="text" id="name" required
            class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:border-blue-600">
        </div>

        <div>
          <label class="block font-bold mb-2">Mô tả</label>
          <input type="text" id="description"
            class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:border-blue-600">
        </div>

        <div>
          <label class="block font-bold mb-2">Ảnh danh mục</label>
          <input type="file" id="image" accept="image/*"
            class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:border-blue-600">
        </div>
      </div>

      <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded">
        Thêm danh mục
      </button>
    </form>
  </div>

  <!-- DANH SÁCH -->
  <% if (categories && categories.length > 0) { %>
    <div class="bg-white rounded-lg shadow-lg overflow-hidden">
      <table class="w-full">
        <thead class="bg-blue-600 text-white">
          <tr>
            <th class="px-4 py-3 text-left">Ảnh</th>
            <th class="px-4 py-3 text-left">Tên</th>
            <th class="px-4 py-3 text-left">Mô tả</th>
            <th class="px-4 py-3 text-center">Hành động</th>
          </tr>
        </thead>
        <tbody class="divide-y">
          <% categories.forEach(category => { %>
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-4">
                <% if (category.image) { %>
                  <img src="<%= category.image %>" alt="<%= category.name %>" class="w-14 h-14 object-cover rounded border">
                <% } else { %>
                  <div class="w-14 h-14 rounded border bg-gray-100 flex items-center justify-center text-gray-400">🖼️</div>
                <% } %>
              </td>
              <td class="px-4 py-4 font-bold"><%= category.name %></td>
              <td class="px-4 py-4"><%= category.description || '' %></td>
              <td class="px-4 py-4 text-center space-x-3">

                <!-- DATA ATTRIBUTES AN TOÀN -->
                <button
                  data-id="<%= category._id %>"
                  data-name="<%= category.name %>"
                  data-description="<%= category.description || '' %>"
                  data-image="<%= category.image || '' %>"
                  onclick="editCategory(this)"
                  class="text-blue-600 font-bold">
                  Sửa
                </button>

                <button
                  onclick="deleteCategory('<%= category._id %>')"
                  class="text-red-600 font-bold">
                  Xóa
                </button>

              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } else { %>
    <div class="bg-white p-8 text-center">
      Không có danh mục nào
    </div>
  <% } %>
</div>

<!-- MODAL -->
<div id="editModal" class="hidden fixed inset-0 bg-black bg-opacity-50 items-center justify-center">
  <div class="bg-white p-6 rounded w-96">
    <h2 class="text-xl font-bold mb-4">Chỉnh sửa</h2>

    <input type="hidden" id="editId">

    <div class="mb-3">
      <label class="block font-bold">Tên</label>
      <input type="text" id="editName" class="w-full border px-3 py-2 rounded">
    </div>

    <div class="mb-3">
      <label class="block font-bold">Mô tả</label>
      <input type="text" id="editDescription" class="w-full border px-3 py-2 rounded">
    </div>

    <div class="mb-3">
      <label class="block font-bold">Ảnh hiện tại</label>
      <img id="editCurrentImage" class="w-20 h-20 object-cover rounded border hidden mb-2" alt="category image">
      <input type="file" id="editImage" accept="image/*" class="w-full border px-3 py-2 rounded">
    </div>

    <div class="flex gap-3">
      <button onclick="saveCategory()" class="bg-blue-600 text-white px-4 py-2 rounded flex-1">
        Lưu
      </button>
      <button onclick="closeModal()" class="bg-gray-400 text-white px-4 py-2 rounded flex-1">
        Hủy
      </button>
    </div>
  </div>
</div>

<script>

function notify(message) {
  alert(message); // tạm dùng alert cho chắc chắn không lỗi
}

/* =========================
   THÊM DANH MỤC
========================= */
function addCategory(event) {
  event.preventDefault();

  const name = document.getElementById('name').value;
  const description = document.getElementById('description').value;
  const imageFile = document.getElementById('image').files[0];

  const formData = new FormData();
  formData.append('name', name);
  formData.append('description', description);
  if (imageFile) {
    formData.append('image', imageFile);
  }

  fetch('/admin/categories/add', {
    method: 'POST',
    body: formData
  })
  .then(res => res.json())
  .then(data => {
    if (data.success) {
      notify('Thêm thành công');
      location.reload();
    } else {
      notify(data.error || 'Có lỗi');
    }
  })
  .catch(err => {
    console.error(err);
    notify('Lỗi server');
  });
}

/* =========================
   MỞ MODAL
========================= */
function editCategory(btn) {
  document.getElementById('editId').value = btn.dataset.id;
  document.getElementById('editName').value = btn.dataset.name;
  document.getElementById('editDescription').value = btn.dataset.description;
  document.getElementById('editImage').value = '';

  const preview = document.getElementById('editCurrentImage');
  if (btn.dataset.image) {
    preview.src = btn.dataset.image;
    preview.classList.remove('hidden');
  } else {
    preview.classList.add('hidden');
    preview.src = '';
  }

  document.getElementById('editModal').classList.remove('hidden');
  document.getElementById('editModal').classList.add('flex');
}

function closeModal() {
  document.getElementById('editModal').classList.remove('flex');
  document.getElementById('editModal').classList.add('hidden');
}

/* =========================
   LƯU CHỈNH SỬA
========================= */
function saveCategory() {
  const id = document.getElementById('editId').value;
  const name = document.getElementById('editName').value;
  const description = document.getElementById('editDescription').value;
  const imageFile = document.getElementById('editImage').files[0];

  const formData = new FormData();
  formData.append('name', name);
  formData.append('description', description);
  if (imageFile) {
    formData.append('image', imageFile);
  }

  fetch('/admin/categories/' + id + '/edit', {
    method: 'POST',
    body: formData
  })
  .then(res => res.json())
  .then(data => {
    if (data.success) {
      notify('Cập nhật thành công');
      location.reload();
    } else {
      notify(data.error || 'Có lỗi');
    }
  })
  .catch(err => {
    console.error(err);
    notify('Lỗi server');
  });
}

/* =========================
   XÓA
========================= */
function deleteCategory(id) {
  if (!confirm('Bạn chắc chắn muốn xóa?')) return;

  fetch('/admin/categories/' + id + '/delete', {
    method: 'POST'
  })
  .then(res => res.json())
  .then(data => {
    if (data.success) {
      notify('Xóa thành công');
      location.reload();
    } else {
      notify(data.error || 'Có lỗi');
    }
  })
  .catch(err => {
    console.error(err);
    notify('Lỗi server');
  });
}

</script>