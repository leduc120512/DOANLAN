<div class="py-8">
  <div class="flex justify-between mb-8">
    <h1 class="text-4xl font-bold text-blue-600">
      Quản lý sản phẩm
    </h1>
    <a href="/admin/products/add" class="btn-primary">
      + Thêm sản phẩm
    </a>
  </div>

  <% if (products && products.length > 0) { %>
  <div class="bg-white shadow rounded-lg overflow-hidden">
    <table class="w-full">
      <thead class="bg-blue-600 text-white">
        <tr>
          <th class="p-3 text-left">Sản phẩm</th>
          <th class="p-3 text-center">Số ảnh</th>
          <th class="p-3 text-center">Giá</th>
          <th class="p-3 text-center">Kho</th>
          <th class="p-3 text-center">Hành động</th>
        </tr>
      </thead>

      <tbody class="divide-y">
        <% products.forEach(product => { %>
        <% const displayImage = (product.images && product.images.length > 0) ? product.images[0] : product.image; %>
        <% const imageCount = (product.images && product.images.length > 0) ? product.images.length : (product.image ? 1 : 0); %>
        <tr class="hover:bg-gray-50">

          <!-- PRODUCT INFO + IMAGE -->
          <td class="p-3">
            <div class="flex items-center gap-4">
              
              <% if (displayImage) { %>
                <img 
                  src="<%= displayImage %>" 
                  class="w-14 h-14 object-cover rounded border"
                >
              <% } else { %>
                <div class="w-14 h-14 flex items-center justify-center bg-gray-200 rounded">
                
                </div>
              <% } %>

              <div>
                <p class="font-bold">
                  <%= product.name %>
                </p>
                <p class="text-xs text-gray-500">
                  ID: <%= product._id %>
                </p>
              </div>

            </div>
          </td>

          <!-- IMAGE COUNT -->
          <td class="p-3 text-center">
            <span class="inline-flex items-center justify-center min-w-12 px-2 py-1 rounded-full bg-blue-50 text-blue-700 font-semibold">
              <%= imageCount %>
            </span>
          </td>

          <!-- PRICE -->
          <td class="p-3 text-center text-red-600 font-semibold">
            <%= product.price ? product.price.toLocaleString() : 0 %> đ
          </td>

          <!-- STOCK -->
          <td class="p-3 text-center">
            <% if (product.stock > 0) { %>
              <span class="text-green-600 font-bold">
                <%= product.stock %>
              </span>
            <% } else { %>
              <span class="text-red-500 font-bold">
                Hết hàng
              </span>
            <% } %>
          </td>

          <!-- ACTIONS -->
          <td class="p-3 text-center">
            <div class="flex justify-center gap-4">

              <a 
                href="/admin/products/<%= product._id %>/edit"
                class="text-blue-600 hover:underline"
              >
                Sửa
              </a>

              <form 
                action="/admin/products/<%= product._id %>/delete" 
                method="POST"
              >
                <button 
                  onclick="return confirm('Xóa sản phẩm?')" 
                  class="text-red-600 hover:underline"
                >
                  Xóa
                </button>
              </form>

            </div>
          </td>

        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <% } else { %>
  <div class="bg-white p-8 rounded shadow text-center text-gray-500">
    Không có sản phẩm
  </div>
  <% } %>
</div>