<div class="py-8">
    <h1 class="text-4xl font-bold mb-8 text-blue-600">Thông tin cá nhân</h1>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Profile Form -->
      <div class="lg:col-span-2">
        <div class="bg-white rounded-lg shadow-lg p-8 mb-8">
          <h2 class="text-2xl font-bold mb-6 text-blue-600">Chỉnh sửa thông tin</h2>
          <form id="profileForm">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
              <div>
                <label class="block text-gray-700 font-bold mb-2">Họ và tên</label>
                <input type="text" id="fullName" value="<%= user.fullName %>" class="w-full px-4 py-2 border-2 border-blue-200 rounded-lg focus:outline-none focus:border-blue-600">
              </div>
              <div>
                <label class="block text-gray-700 font-bold mb-2">Email</label>
                <input type="email" value="<%= user.email %>" class="w-full px-4 py-2 border-2 border-blue-200 rounded-lg bg-gray-100" readonly>
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
              <div>
                <label class="block text-gray-700 font-bold mb-2">Số điện thoại</label>
                <input type="tel" id="phone" value="<%= user.phone %>" class="w-full px-4 py-2 border-2 border-blue-200 rounded-lg focus:outline-none focus:border-blue-600">
              </div>
              <div>
                <label class="block text-gray-700 font-bold mb-2">Địa chỉ</label>
                <input type="text" id="address" value="<%= user.address %>" class="w-full px-4 py-2 border-2 border-blue-200 rounded-lg focus:outline-none focus:border-blue-600">
              </div>
            </div>

            <button type="button" onclick="updateProfile()" class="btn-primary">Cập nhật thông tin</button>
          </form>
        </div>

        <!-- Change Password -->
        <div class="bg-white rounded-lg shadow-lg p-8">
          <h2 class="text-2xl font-bold mb-6 text-blue-600">Đổi mật khẩu</h2>
          <form id="passwordForm">
            <div class="mb-4">
              <label class="block text-gray-700 font-bold mb-2">Mật khẩu cũ</label>
              <input type="password" id="oldPassword" class="w-full px-4 py-2 border-2 border-blue-200 rounded-lg focus:outline-none focus:border-blue-600">
            </div>

            <div class="mb-4">
              <label class="block text-gray-700 font-bold mb-2">Mật khẩu mới</label>
              <input type="password" id="newPassword" class="w-full px-4 py-2 border-2 border-blue-200 rounded-lg focus:outline-none focus:border-blue-600">
            </div>

            <div class="mb-6">
              <label class="block text-gray-700 font-bold mb-2">Xác nhận mật khẩu mới</label>
              <input type="password" id="confirmPassword" class="w-full px-4 py-2 border-2 border-blue-200 rounded-lg focus:outline-none focus:border-blue-600">
            </div>

            <button type="button" onclick="changePassword()" class="btn-primary">Đổi mật khẩu</button>
          </form>
        </div>
      </div>

      <!-- Sidebar -->
      <div>
        <div class="bg-blue-50 border-2 border-blue-200 rounded-lg p-6 sticky top-20">
          <h3 class="text-xl font-bold mb-4 text-blue-600">Thông tin tài khoản</h3>
          <ul class="space-y-3 text-gray-700">
            <li><strong>Email:</strong> <%= user.email %></li>
            <li><strong>Số điện thoại:</strong> <%= user.phone %></li>
            <li><strong>Địa chỉ:</strong> <%= user.address %></li>
            <li><strong>Loại:</strong> <span class="text-blue-600 font-bold"><%= user.role === 'admin' ? 'Quản trị viên' : 'Khách hàng' %></span></li>
          </ul>
          <a href="/order/my-orders" class="block mt-6 w-full btn-primary text-center">Xem đơn hàng</a>
          <a href="/user/notifications" class="block mt-2 w-full btn-primary text-center">Xem thông báo</a>
          <a href="/auth/logout" class="block mt-2 w-full btn-secondary text-center">Đăng xuất</a>
        </div>
      </div>
    </div>
  </div>

  <script>
    function updateProfile() {
      const fullName = document.getElementById('fullName').value;
      const phone = document.getElementById('phone').value;
      const address = document.getElementById('address').value;

      fetch('/user/profile/update', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ fullName, phone, address })
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          notify('Cập nhật thông tin thành công', 'success');
        } else {
          notify(data.error, 'error');
        }
      });
    }

    function changePassword() {
      const oldPassword = document.getElementById('oldPassword').value;
      const newPassword = document.getElementById('newPassword').value;
      const confirmPassword = document.getElementById('confirmPassword').value;

      if (!oldPassword || !newPassword || !confirmPassword) {
        notify('Vui lòng nhập đầy đủ thông tin', 'error');
        return;
      }

      fetch('/user/change-password', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ oldPassword, newPassword, confirmPassword })
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          notify('Đổi mật khẩu thành công', 'success');
          document.getElementById('passwordForm').reset();
        } else {
          notify(data.error, 'error');
        }
      });
    }
  </script>
</div>
