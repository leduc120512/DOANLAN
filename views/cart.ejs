<div class="py-8">
    <h1 class="text-4xl font-bold mb-8 text-blue-600">Giỏ hàng</h1>

    <% if (cart && cart.length > 0) { %>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Cart Items -->
        <div class="lg:col-span-2">
          <div class="bg-white rounded-lg shadow-lg overflow-hidden">
            <table class="w-full">
              <thead class="bg-blue-600 text-white">
                <tr>
                  <th class="px-4 py-3 text-left">Sản phẩm</th>
                  <th class="px-4 py-3 text-center">Giá</th>
                  <th class="px-4 py-3 text-center">Số lượng</th>
                  <th class="px-4 py-3 text-center">Tổng</th>
                  <th class="px-4 py-3 text-center">Xóa</th>
                </tr>
              </thead>
              <tbody class="divide-y">
                <% cart.forEach(item => { %>
                  <tr class="hover:bg-gray-50">
                    <td class="px-4 py-4">
                      <div class="flex items-center gap-4">
                        <% if (item.image) { %>
                          <img src="<%= item.image %>" alt="<%= item.name %>" class="w-16 h-16 object-cover rounded">
                        <% } else { %>
                          <span class="text-3xl">📦</span>
                        <% } %>
                        <div>
                          <p class="font-bold"><%= item.name %></p>
                        </div>
                      </div>
                    </td>
                    <td class="px-4 py-4 text-center"><%= item.price.toLocaleString() %>₫</td>
                    <td class="px-4 py-4">
                      <div class="flex items-center justify-center border-2 border-blue-200 rounded-lg w-28 mx-auto">
                        <button class="px-3 py-1 text-blue-600 font-bold" onclick="updateQty('<%= item.productId %>', <%= item.quantity - 1 %>)">-</button>
                        <input type="number" value="<%= item.quantity %>" class="w-12 text-center border-l border-r border-blue-200 py-1" readonly>
                        <button class="px-3 py-1 text-blue-600 font-bold" onclick="updateQty('<%= item.productId %>', <%= item.quantity + 1 %>)">+</button>
                      </div>
                    </td>
                    <td class="px-4 py-4 text-center font-bold text-blue-600"><%= (item.price * item.quantity).toLocaleString() %>₫</td>
                    <td class="px-4 py-4 text-center">
                      <button class="text-red-500 hover:text-red-700 font-bold" onclick="removeFromCart('<%= item.productId %>')">Xóa</button>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Order Summary -->
        <div class="lg:col-span-1">
          <div class="bg-blue-50 border-2 border-blue-200 rounded-lg p-6 sticky top-20">
            <h2 class="text-2xl font-bold mb-6 text-blue-600">Tóm tắt đơn hàng</h2>
            
            <div class="space-y-3 mb-6">
              <div class="flex justify-between">
                <span>Tổng sản phẩm:</span>
                <span class="font-bold"><%= cart.length %></span>
              </div>
              <div class="flex justify-between text-xl font-bold text-blue-600 border-t pt-3">
                <span>Tổng cộng:</span>
                <span><%= total.toLocaleString() %>₫</span>
              </div>
            </div>

            <% if (user) { %>
              <a href="/order/checkout" class="block w-full bg-blue-600 text-white py-3 rounded-lg font-bold text-center hover:bg-blue-700 mb-3">Tiến hành thanh toán</a>
            <% } else { %>
              <a href="/auth/login" class="block w-full bg-blue-600 text-white py-3 rounded-lg font-bold text-center hover:bg-blue-700 mb-3">Đăng nhập để thanh toán</a>
            <% } %>
            <a href="/" class="block w-full btn-secondary text-center">Tiếp tục mua hàng</a>
          </div>
        </div>
      </div>
    <% } else { %>
      <div class="bg-white rounded-lg shadow-lg p-12 text-center">
        <p class="text-gray-600 text-2xl mb-6">Giỏ hàng trống</p>
        <a href="/" class="btn-primary">Quay lại mua hàng</a>
      </div>
    <% } %>
  </div>

  <script>
    function updateQty(productId, quantity) {
      if (quantity < 1) return;
      
      fetch('/cart/update', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ productId, quantity })
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          location.reload();
        } else {
          notify(data.error, 'error');
        }
      });
    }

    function removeFromCart(productId) {
      fetch('/cart/remove', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ productId })
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          location.reload();
        } else {
          notify(data.error, 'error');
        }
      });
    }
  </script>
</div>
