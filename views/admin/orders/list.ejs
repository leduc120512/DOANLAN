<div class="py-8">
  <h1 class="text-4xl font-bold mb-8 text-blue-600">
    Quản lý đơn hàng
  </h1>

  <!-- Search & Filter -->
  <div class="bg-white rounded-lg shadow-lg p-6 mb-8">
    <form method="GET" action="/admin/orders" class="flex gap-4 flex-wrap">
      <input
        type="text"
        name="search"
        value="<%= search || '' %>"
        placeholder="Tìm theo tên hoặc SĐT..."
        class="flex-1 min-w-48 px-4 py-2 border-2 border-blue-200 rounded-lg"
      />

      <select
        name="status"
        class="px-4 py-2 border-2 border-blue-200 rounded-lg"
      >
        <option value="all" <%= selectedStatus === 'all' ? 'selected' : '' %>>
          Tất cả trạng thái
        </option>
        <option value="Pending" <%= selectedStatus === 'Pending' ? 'selected' : '' %>>
          Pending
        </option>
        <option value="Processing" <%= selectedStatus === 'Processing' ? 'selected' : '' %>>
          Processing
        </option>
        <option value="Shipped" <%= selectedStatus === 'Shipped' ? 'selected' : '' %>>
          Shipped
        </option>
        <option value="Delivered" <%= selectedStatus === 'Delivered' ? 'selected' : '' %>>
          Delivered
        </option>
        <option value="Cancelled" <%= selectedStatus === 'Cancelled' ? 'selected' : '' %>>
          Cancelled
        </option>
      </select>

      <button type="submit" class="btn-primary">
        Lọc
      </button>

      <a href="/admin/orders" class="btn-secondary">
        Xóa
      </a>
    </form>
  </div>

  <!-- Orders Table -->
  <% if (orders && orders.length > 0) { %>
    <div class="bg-white rounded-lg shadow-lg overflow-hidden">
      <table class="w-full">
        <thead class="bg-blue-600 text-white">
          <tr>
            <th class="px-4 py-3 text-left">Mã đơn hàng</th>
            <th class="px-4 py-3 text-left">Khách hàng</th>
            <th class="px-4 py-3 text-center">Ngày tạo</th>
            <th class="px-4 py-3 text-right">Tổng tiền</th>
            <th class="px-4 py-3 text-center">Trạng thái</th>
            <th class="px-4 py-3 text-center">Hành động</th>
          </tr>
        </thead>

        <tbody class="divide-y">
          <% orders.forEach(order => { %>
            <tr class="hover:bg-gray-50">
              
              <!-- Order ID -->
              <td class="px-4 py-4 font-bold text-blue-600">
                #<%= order._id.toString().slice(-8).toUpperCase() %>
              </td>

              <!-- Customer -->
              <td class="px-4 py-4">
                <p class="font-bold">
                  <%= order.customerName || '---' %>
                </p>
                <p class="text-gray-600 text-sm">
                  <%= order.customerPhone || '' %>
                </p>
              </td>

              <!-- Date -->
              <td class="px-4 py-4 text-center">
                <%= order.createdAt 
                    ? new Date(order.createdAt).toLocaleDateString('vi-VN') 
                    : '' %>
              </td>

              <!-- Total -->
              <td class="px-4 py-4 text-right font-bold">
                <%= order.totalPrice 
                    ? order.totalPrice.toLocaleString() 
                    : 0 %>₫
                <% if (order.couponCode) { %>
                  <p class="text-xs text-green-600 font-semibold mt-1">Mã: <%= order.couponCode %></p>
                <% } %>
              </td>

              <!-- Status -->
              <td class="px-4 py-4 text-center">
                <span class="px-3 py-1 rounded-full text-sm font-bold
                  <%= order.status === 'Pending' ? 'bg-yellow-100 text-yellow-600' :
                      order.status === 'Processing' ? 'bg-blue-100 text-blue-600' :
                      order.status === 'Shipped' ? 'bg-purple-100 text-purple-600' :
                      order.status === 'Delivered' ? 'bg-green-100 text-green-600' :
                      'bg-red-100 text-red-600' %>">
                  <%= order.status %>
                </span>
              </td>

              <!-- Actions -->
              <td class="px-4 py-4 text-center">
                <a href="/admin/orders/<%= order._id %>"
                   class="text-blue-600 hover:underline font-bold">
                  Xem
                </a>
              </td>

            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } else { %>
    <div class="bg-white rounded-lg shadow-lg p-8 text-center text-gray-500">
      Không có đơn hàng nào
    </div>
  <% } %>
</div>