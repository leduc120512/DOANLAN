<div class="py-8">
  <h1 class="text-3xl font-bold mb-6 text-blue-600">Thêm sản phẩm</h1>

  <% const uploadError = typeof error !== 'undefined' ? error : null; %>

  <% if (uploadError) { %>
    <div class="mb-4 p-3 rounded border border-red-300 bg-red-50 text-red-700">
      <div><strong>Lỗi upload:</strong> <%= uploadError.message %></div>
      <% if (uploadError.code) { %>
        <div>Mã lỗi: <%= uploadError.code %></div>
      <% } %>
      <% if (uploadError.field) { %>
        <div>Field: <%= uploadError.field %></div>
      <% } %>
    </div>

    <script>
      console.error("[UPLOAD_DEBUG] add-product", <%- JSON.stringify(uploadError || null) %>);
    </script>
  <% } %>

  <form action="/admin/products/add" method="POST" enctype="multipart/form-data" class="bg-white p-6 rounded shadow">

    <input name="name" placeholder="Tên sản phẩm" class="w-full mb-4 p-2 border rounded" required>

    <textarea name="description" placeholder="Mô tả" class="w-full mb-4 p-2 border rounded" required></textarea>

    <input type="number" name="price" placeholder="Giá" class="w-full mb-4 p-2 border rounded" required>

    <input type="number" name="stock" placeholder="Kho" class="w-full mb-4 p-2 border rounded" required>

    <select name="category" class="w-full mb-4 p-2 border rounded" required>
      <option value="">Chọn danh mục</option>
      <% categories.forEach(cat => { %>
        <option value="<%= cat._id %>"><%= cat.name %></option>
      <% }) %>
    </select>

    <label class="block text-sm text-gray-600 mb-2">Ảnh sản phẩm (có thể chọn nhiều ảnh)</label>
    <input type="file" name="images" accept="image/*" multiple class="mb-4">

    <button class="btn-primary">Thêm sản phẩm</button>
  </form>
</div>