<div class="py-8">
    <h1 class="text-4xl font-bold mb-8 text-blue-600">Admin Dashboard</h1>

    <!-- Stats -->
    <div class="grid grid-cols-1 md:grid-cols-6 gap-6 mb-8">
      <div class="bg-white rounded-lg shadow-lg p-6 border-l-4 border-blue-600">
        <h3 class="text-gray-600 text-sm font-bold mb-2">Tổng sản phẩm</h3>
        <p class="text-4xl font-bold text-blue-600"><%= stats.totalProducts %></p>
      </div>
      <div class="bg-white rounded-lg shadow-lg p-6 border-l-4 border-green-600">
        <h3 class="text-gray-600 text-sm font-bold mb-2">Tổng đơn hàng</h3>
        <p class="text-4xl font-bold text-green-600"><%= stats.totalOrders %></p>
      </div>
      <div class="bg-white rounded-lg shadow-lg p-6 border-l-4 border-purple-600">
        <h3 class="text-gray-600 text-sm font-bold mb-2">Tổng danh mục</h3>
        <p class="text-4xl font-bold text-purple-600"><%= stats.totalCategories %></p>
      </div>
      <div class="bg-white rounded-lg shadow-lg p-6 border-l-4 border-orange-600">
        <h3 class="text-gray-600 text-sm font-bold mb-2">Tổng doanh thu</h3>
        <p class="text-2xl font-bold text-orange-600"><%= stats.totalRevenue.toLocaleString() %>₫</p>
      </div>
      <div class="bg-white rounded-lg shadow-lg p-6 border-l-4 border-pink-600">
        <h3 class="text-gray-600 text-sm font-bold mb-2">Tổng banner</h3>
        <p class="text-4xl font-bold text-pink-600"><%= stats.totalBanners || 0 %></p>
      </div>
      <div class="bg-white rounded-lg shadow-lg p-6 border-l-4 border-indigo-600">
        <h3 class="text-gray-600 text-sm font-bold mb-2">Tổng mã giảm giá</h3>
        <p class="text-4xl font-bold text-indigo-600"><%= stats.totalCoupons || 0 %></p>
      </div>
      <div class="bg-white rounded-lg shadow-lg p-6 border-l-4 border-red-600">
        <h3 class="text-gray-600 text-sm font-bold mb-2">Tổng báo cáo sản phẩm</h3>
        <p class="text-4xl font-bold text-red-600"><%= stats.totalReports || 0 %></p>
      </div>
    </div>

    <!-- Quick Links -->
    <div class="bg-white rounded-lg shadow-lg p-8">
      <h2 class="text-2xl font-bold mb-6 text-blue-600">Quản lý</h2>
      <div class="grid grid-cols-1 md:grid-cols-5 gap-4">
        <a href="/admin/products" class="bg-blue-100 hover:bg-blue-200 text-blue-600 font-bold py-4 px-6 rounded-lg text-center transition">
      Quản lý sản phẩm
        </a>
        <a href="/admin/categories" class="bg-purple-100 hover:bg-purple-200 text-purple-600 font-bold py-4 px-6 rounded-lg text-center transition">
           Quản lý danh mục
        </a>
        <a href="/admin/orders" class="bg-green-100 hover:bg-green-200 text-green-600 font-bold py-4 px-6 rounded-lg text-center transition">
           Quản lý đơn hàng
        </a>
          <a href="/admin/banners" class="bg-pink-100 hover:bg-pink-200 text-pink-600 font-bold py-4 px-6 rounded-lg text-center transition">
            Quản lý banner
          </a>
          <a href="/admin/coupons" class="bg-indigo-100 hover:bg-indigo-200 text-indigo-600 font-bold py-4 px-6 rounded-lg text-center transition">
            Quản lý mã giảm giá
          </a>
          <a href="/admin/reports" class="bg-red-100 hover:bg-red-200 text-red-600 font-bold py-4 px-6 rounded-lg text-center transition">
            Báo cáo sản phẩm
          </a>
      </div>
    </div>
  </div>
</div>
