<div class="py-8 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
  <h1 class="text-3xl md:text-4xl font-bold mb-8 text-blue-700">
    Chi tiết đơn hàng #<%= order._id ?
    order._id.toString().slice(-8).toUpperCase() : '' %>
  </h1>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- LEFT SIDE - Thông tin chính -->
    <div class="lg:col-span-2 space-y-8">
      <!-- Thông tin khách hàng -->
      <div class="bg-white rounded-xl shadow-md p-6 md:p-8">
        <h2 class="text-2xl font-bold mb-6 text-blue-700">
          Thông tin nhận hàng
        </h2>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <div>
            <p class="text-gray-600 text-sm">Người nhận</p>
            <p class="font-semibold text-lg">
              <%= order.customerName || '---' %>
            </p>
          </div>
          <div>
            <p class="text-gray-600 text-sm">Số điện thoại</p>
            <p class="font-semibold text-lg">
              <%= order.customerPhone || '---' %>
            </p>
          </div>
          <div class="sm:col-span-2">
            <p class="text-gray-600 text-sm">Địa chỉ giao hàng</p>
            <p class="font-semibold text-lg">
              <%= order.customerAddress || '---' %>
            </p>
          </div>
          <div>
            <p class="text-gray-600 text-sm">Ngày đặt hàng</p>
            <p class="font-semibold">
              <%= order.createdAt ? new
              Date(order.createdAt).toLocaleString('vi-VN') : '---' %>
            </p>
          </div>
          <div>
            <p class="text-gray-600 text-sm">Trạng thái đơn hàng</p>
            <p
              class="font-bold text-lg <%= order.status === 'Delivered' || order.status === 'Completed' ? 'text-green-600' : order.status === 'Cancelled' ? 'text-red-600' : 'text-orange-600' %>"
            >
              <%= order.status === 'Delivered' ? 'Đã giao hàng' : order.status
              === 'Completed' ? 'Hoàn thành' : order.status === 'Shipped' ?
              'Đang vận chuyển' : order.status === 'Processing' ? 'Đang xử lý' :
              order.status === 'Pending' ? 'Chờ xác nhận' : order.status ===
              'Cancelled' ? 'Đã hủy' : order.status %>
            </p>
          </div>
        </div>
      </div>

      <!-- Danh sách sản phẩm -->
      <div class="bg-white rounded-xl shadow-md p-6 md:p-8">
        <h2 class="text-2xl font-bold mb-6 text-blue-700">
          Sản phẩm trong đơn hàng
        </h2>

        <div class="space-y-6">
          <% if (order.items && order.items.length > 0) { %> <%
          order.items.forEach(item => { %>
          <div
            class="flex flex-col sm:flex-row sm:items-center gap-4 border-b pb-6 last:border-b-0 last:pb-0"
          >
            <div class="w-24 h-24 bg-gray-100 rounded-lg flex-shrink-0">
              <!-- Nếu có ảnh sản phẩm thì thêm ở đây -->
              <!-- <img src="<%= item.product?.image || '/placeholder.jpg' %>" alt="" class="w-full h-full object-cover rounded-lg"> -->
            </div>
            <div class="flex-1">
              <h3 class="font-semibold text-lg">
                <%= item.product?.name || 'Sản phẩm đã xóa' %>
              </h3>
              <p class="text-gray-600 mt-1">
                Giá: <%= item.price ? item.price.toLocaleString('vi-VN') : 0 %>₫
                × <%= item.quantity || 1 %>
              </p>
            </div>
            <div class="text-right font-bold text-lg min-w-[120px]">
              <%= (item.price * item.quantity).toLocaleString('vi-VN') %>₫
            </div>
          </div>
          <% }) %> <% } else { %>
          <p class="text-center text-gray-500 py-8">
            Không có sản phẩm trong đơn hàng này
          </p>
          <% } %>
        </div>

        <!-- Tổng kết -->
        <div class="mt-8 pt-6 border-t">
          <div class="flex justify-between text-lg">
            <span>Tổng số lượng:</span>
            <span class="font-semibold">
              <%= order.items?.reduce((sum, i) => sum + (i.quantity || 0), 0) ||
              0 %>
            </span>
          </div>
          <div class="flex justify-between text-lg mt-2">
            <span>Tạm tính:</span>
            <span class="font-semibold">
              <%= (order.subtotalPrice || order.totalPrice || 0).toLocaleString('vi-VN') %>₫
            </span>
          </div>
          <% if (order.discountAmount && order.discountAmount > 0) { %>
            <div class="flex justify-between text-lg mt-2 text-green-600">
              <span>Giảm giá <%= order.couponCode ? '(' + order.couponCode + ')' : '' %>:</span>
              <span class="font-semibold">-<%= order.discountAmount.toLocaleString('vi-VN') %>₫</span>
            </div>
          <% } %>
          <div
            class="flex justify-between text-2xl font-bold mt-3 text-blue-700"
          >
            <span>Tổng tiền:</span>
            <span
              ><%= order.totalPrice ? order.totalPrice.toLocaleString('vi-VN') :
              0 %>₫</span
            >
          </div>
        </div>
      </div>
    </div>

    <!-- RIGHT SIDE - Đánh giá (chỉ hiện khi hoàn thành) -->
    <div class="lg:col-span-1">
      <div class="bg-white rounded-xl shadow-md p-6 sticky top-8">
        <% if (order.status === 'Delivered' || order.status === 'Completed') {
        %>
        <h2 class="text-2xl font-bold mb-6 text-green-700">
          Đánh giá sản phẩm
        </h2>
        <p class="text-gray-600 mb-6">
          Đơn hàng đã hoàn thành. Bạn có thể đánh giá sản phẩm ngay bây giờ!
        </p>

        <% order.items.forEach(item => { %> <% if (item.product) { %>
        <div class="mb-8 last:mb-0">
          <p class="font-semibold mb-3"><%= item.product.name %></p>

          <form
            action="/order/<%= item.product._id %>/comment"
            method="POST"
            class="space-y-4"
          >
            <div>
              <label class="block text-sm text-gray-700 mb-2 font-medium"
                >Đánh giá (sao)</label
              >
              <select
                name="rating"
                required
                class="w-full border border-gray-300 rounded-lg px-4 py-2.5"
              >
                <option value="">Chọn số sao</option>
                <option value="5">5 ★★★★★ Tuyệt vời</option>
                <option value="4">4 ★★★★☆ Tốt</option>
                <option value="3">3 ★★★☆☆ Bình thường</option>
                <option value="2">2 ★★☆☆☆ Không hài lòng</option>
                <option value="1">1 ★☆☆☆☆ Rất tệ</option>
              </select>
            </div>

            <div>
              <label class="block text-sm text-gray-700 mb-2 font-medium"
                >Nhận xét của bạn</label
              >
              <textarea
                name="text"
                rows="4"
                required
                class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:ring-blue-500 focus:border-blue-500"
                placeholder="Chia sẻ trải nghiệm của bạn về sản phẩm..."
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full bg-green-600 hover:bg-green-700 text-white font-medium py-3 px-6 rounded-lg transition"
            >
              Gửi đánh giá
            </button>
          </form>
        </div>
        <% } %> <% }) %> <% } else { %>
        <h2 class="text-xl font-bold mb-4 text-gray-700">
          Trạng thái đơn hàng
        </h2>
        <p class="text-gray-600">
          Bạn chỉ có thể đánh giá sản phẩm sau khi đơn hàng được giao thành công
          (<strong>Đã giao hàng</strong> hoặc <strong>Hoàn thành</strong>).
        </p>
        <% } %>

        <!-- Nút quay lại -->
        <a
          href="/my-orders"
          class="block w-full mt-8 text-center py-3 px-6 border border-gray-300 rounded-lg hover:bg-gray-50 transition"
        >
          Quay lại danh sách đơn hàng
        </a>
      </div>
    </div>
  </div>
</div>
